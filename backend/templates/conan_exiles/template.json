{
  "id": "conan_exiles",
  "name": "Conan Exiles",
  "category": "survival",
  "appid": 443030,
  "anon": true,
  "ports": [
    { "port": 7777, "protocol": "udp", "primary": true },
    { "port": 7778, "protocol": "udp" },
    { "port": 27015, "protocol": "udp" }
  ],
  "queryPort": 27015,
  "stop": { "type": "signal", "signal": "SIGTERM" },
  "readyPattern": "Server has started",
  "config": { "type": "ini", "file": "Engine.ini" },
  "workshopProvider": "steam",
  "defaultRamMb": 8192,
  "fields": [
    { "envVar": "SERVER_NAME", "label": "Server Name", "type": "text", "default": "ForgePanel Conan Server", "iniKey": "ServerName", "iniSection": "Game.Session" },
    { "envVar": "ADMIN_PASSWORD", "label": "Admin Password", "type": "password", "default": "", "iniKey": "AdminPassword", "iniSection": "Game.Session" },
    { "envVar": "SERVER_PASSWORD", "label": "Server Password", "type": "password", "default": "", "iniKey": "ServerPassword", "iniSection": "Game.Session" },
    { "envVar": "MAXPLAYERS", "label": "Max Players", "type": "number", "default": 40, "iniKey": "MaxPlayers", "iniSection": "Game.Session" },
    { "envVar": "PVP_ENABLED", "label": "PVP Enabled", "type": "bool", "default": true, "iniKey": "PvPEnabled", "iniSection": "Game.Session" },
    { "envVar": "CONTAINER_IGNORE_OWNERSHIP", "label": "Container Ignore Ownership", "type": "bool", "default": false, "iniKey": "ContainerIgnoreOwnership", "iniSection": "Game.Session" },
    { "envVar": "SERVER_REGION", "label": "Server Region", "type": "text", "options": ["NA", "EU", "APAC", "SA"], "default": "NA", "iniKey": "ServerRegion", "iniSection": "Game.Session" }
  ]
}
