{
  "id": "ark_evolved",
  "name": "ARK: Survival Evolved",
  "category": "survival",
  "appid": 376030,
  "anon": true,
  "ports": [
    { "port": 7777, "protocol": "udp", "primary": true },
    { "port": 7778, "protocol": "udp" },
    { "port": 27015, "protocol": "udp" }
  ],
  "stop": { "type": "signal", "signal": "SIGTERM" },
  "readyPattern": "Server has started",
  "config": { "type": "ini", "file": "GameUserSettings.ini" },
  "workshopProvider": "steam",
  "workshopAppid": 346110,
  "defaultRamMb": 8192,
  "fields": [
    { "envVar": "SERVER_NAME", "label": "Server Name", "type": "text", "default": "ForgePanel ARK Server", "iniKey": "SessionName", "iniSection": "SessionSettings" },
    { "envVar": "ADMIN_PASSWORD", "label": "Admin Password", "type": "password", "default": "", "iniKey": "ServerAdminPassword", "iniSection": "ServerSettings" },
    { "envVar": "SERVER_PASSWORD", "label": "Server Password", "type": "password", "default": "", "iniKey": "ServerPassword", "iniSection": "ServerSettings" },
    { "envVar": "MAXPLAYERS", "label": "Max Players", "type": "number", "default": 70, "iniKey": "MaxPlayers", "iniSection": "ServerSettings" , "requiresRestart": true },
    { "envVar": "MAP", "label": "Map", "type": "text", "default": "TheIsland", "iniKey": "Map", "iniSection": "ServerSettings" },
    { "envVar": "HARVEST_MULTIPLIER", "label": "Harvest Multiplier", "type": "number", "default": 1, "iniKey": "HarvestAmountMultiplier", "iniSection": "ServerSettings" },
    { "envVar": "XP_MULTIPLIER", "label": "XP Multiplier", "type": "number", "default": 1, "iniKey": "XPMultiplier", "iniSection": "ServerSettings" },
    { "envVar": "TAMING_MULTIPLIER", "label": "Taming Multiplier", "type": "number", "default": 1, "iniKey": "TamingSpeedMultiplier", "iniSection": "ServerSettings" },
    { "envVar": "PVP", "label": "PVP", "type": "bool", "default": true, "iniKey": "ServerPVP", "iniSection": "ServerSettings" }
  ]
}
