{
  "id": "barotrauma",
  "name": "Barotrauma",
  "category": "other",
  "appid": 1247550,
  "anon": true,
  "ports": [
    { "port": 27015, "protocol": "udp", "primary": true },
    { "port": 27016, "protocol": "udp" }
  ],
  "stop": { "type": "signal", "signal": "SIGTERM" },
  "readyPattern": "Server started",
  "config": { "type": "xml", "file": "serversettings.xml" },
  "workshopProvider": "steam",
  "defaultRamMb": 2048,
  "fields": [
    { "envVar": "NAME", "label": "Server Name", "type": "text", "default": "ForgePanel Barotrauma Server", "xmlTag": "name" },
    { "envVar": "PASSWORD", "label": "Password", "type": "password", "default": "", "xmlTag": "password" },
    { "envVar": "MAX_PLAYERS", "label": "Max Players", "type": "number", "default": 8, "xmlTag": "maxplayers" , "requiresRestart": true },
    { "envVar": "IS_PUBLIC", "label": "Public", "type": "bool", "default": true, "xmlTag": "public" },
    { "envVar": "ALLOW_SPECTATING", "label": "Allow Spectating", "type": "bool", "default": true, "xmlTag": "allowspectating" },
    { "envVar": "ALLOW_RESPAWN", "label": "Allow Respawn", "type": "bool", "default": true, "xmlTag": "allowrespawn" },
    { "envVar": "DIFFICULTY", "label": "Difficulty", "type": "select", "options": ["Easy", "Medium", "Hard", "Hellish"], "default": "Medium", "xmlTag": "difficulty" }
  ]
}
